<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/mainActivitySubirDni"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/principal"
        android:columnCount="3"
        android:rowCount="1"
        android:elevation="12dp">

        <ImageButton
            android:id="@+id/btnHomeUsuario"
            android:layout_column="0"
            android:layout_row="0"
            android:layout_width="130dp"
            android:layout_height="85dp"
            android:layout_marginStart="20dp"
            android:scaleType="fitCenter"
            android:src="@drawable/white_logo"
            android:background="@android:color/transparent"
            android:contentDescription="Volver a home"/>
    </GridLayout>

    <Space
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:layout_gravity="end"
        android:layout_marginTop="10dp"
        android:layout_marginRight="10dp" />

    <ImageView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="20dp"
        android:src="@drawable/usuario_blue"/>

    <TextView
        android:id="@+id/tvUserName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Cargando usuario..."
        android:layout_gravity="center"
        android:textSize="23sp"
        android:layout_marginTop="10dp"
        android:textColor="@color/principal"
        android:fontFamily="@font/montserrat_bold"
        />

    <TextView
        android:id="@+id/tvCompanyName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Empresa"
        android:layout_gravity="center"
        android:textSize="20sp"
        android:layout_marginTop="10dp"
        android:textColor="@color/destacado"
        android:fontFamily="@font/montserrat_bold"
        />

    <ImageButton
        android:id="@+id/btnSubirDNI"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="80dp"
        android:src="@drawable/subir"
        android:background="@android:color/transparent"
        android:layout_gravity="center"
        />

    <Button
        android:id="@+id/btnVolve"
        android:layout_width="200dp"
        android:layout_height="45dp"
        android:layout_marginTop="100dp"
        android:layout_gravity="center"
        android:background="@drawable/btn_blue"
        android:fontFamily="@font/montserrat_bold"
        android:text="Volve"
        android:textColor="@color/background"
        android:textSize="20sp"/>

</LinearLayout>
