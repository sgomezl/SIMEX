<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/mainActivityOperacion"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:orientation="vertical">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/principal"
        android:elevation="12dp">

        <ImageButton
            android:id="@+id/btnHome"
            android:layout_width="130dp"
            android:layout_height="85dp"
            android:layout_marginStart="20dp"
            android:background="@android:color/transparent"
            android:scaleType="fitCenter"
            android:src="@drawable/white_logo"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageButton
            android:id="@+id/btn_notifications"
            android:layout_width="35dp"
            android:layout_height="35dp"
            android:layout_marginEnd="15dp"
            android:background="@android:color/transparent"
            android:scaleType="fitCenter"
            android:src="@drawable/notifications"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/btnUser"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageButton
            android:id="@+id/btnUser"
            android:layout_width="45dp"
            android:layout_height="45dp"
            android:layout_marginEnd="15dp"
            android:background="@android:color/transparent"
            android:padding="5dp"
            android:scaleType="fitCenter"
            android:src="@drawable/login_user"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <TextView
        android:id="@+id/tvOperationReference"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="20dp"
        android:background="@drawable/btn_orange"
        android:fontFamily="@font/montserrat_bold"
        android:paddingHorizontal="10dp"
        android:paddingVertical="5dp"
        android:text="REF-1234567890"
        android:textColor="@color/background"
        android:textSize="20sp" />

    <TextView
        android:id="@+id/tvOperationTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:fontFamily="@font/montserrat_bold"
        android:text="Detalle del envio:"
        android:textColor="@color/principal"
        android:textSize="25sp" />

    <FrameLayout
        android:id="@+id/trackingHeaderContainer"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:layout_marginTop="25dp"
        android:paddingHorizontal="20dp">

        <ImageView
            android:id="@+id/boat"
            android:layout_width="50dp"
            android:layout_height="40dp"
            android:src="@drawable/boat" />

        <ImageView
            android:id="@+id/linear_seguimiento"
            android:layout_width="match_parent"
            android:layout_height="5dp"
            android:layout_gravity="center"
            android:src="@drawable/linea_seguimiento" />

        <TextView
            android:id="@+id/tvOrigin"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|start"
            android:fontFamily="@font/montserrat_bold"
            android:text="Origen"
            android:textColor="@color/principal"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/tvRouteMode"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|center"
            android:fontFamily="@font/montserrat_bold"
            android:text="0%"
            android:textColor="@color/principal"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/tvDestination"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|end"
            android:fontFamily="@font/montserrat_bold"
            android:text="Destino"
            android:textColor="@color/principal"
            android:textSize="12sp" />
    </FrameLayout>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_margin="20dp"
        android:layout_marginTop="12dp"
        android:layout_weight="1"
        app:cardCornerRadius="18dp"
        app:cardElevation="6dp">

        <androidx.fragment.app.FragmentContainerView
            android:id="@+id/mapFragment"
            android:name="com.google.android.gms.maps.SupportMapFragment"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />
    </androidx.cardview.widget.CardView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="50dp"
        android:paddingBottom="20dp">

        <FrameLayout
            android:layout_width="20dp"
            android:layout_height="300dp">

            <ImageView
                android:layout_width="3dp"
                android:layout_height="300dp"
                android:layout_gravity="center"
                android:src="@drawable/linea_seguimiento" />

            <ImageView
                android:id="@+id/ivStep1Dot"
                android:layout_width="15dp"
                android:layout_height="15dp"
                android:layout_gravity="center|top"
                android:src="@drawable/ellipse" />

            <ImageView
                android:id="@+id/ivStep2Dot"
                android:layout_width="15dp"
                android:layout_height="15dp"
                android:layout_gravity="center|top"
                android:layout_marginTop="70dp"
                android:src="@drawable/ellipse" />

            <ImageView
                android:id="@+id/ivStep3Dot"
                android:layout_width="15dp"
                android:layout_height="15dp"
                android:layout_gravity="center"
                android:src="@drawable/ellipse" />

            <ImageView
                android:id="@+id/ivStep4Dot"
                android:layout_width="15dp"
                android:layout_height="15dp"
                android:layout_gravity="center|bottom"
                android:layout_marginBottom="70dp"
                android:src="@drawable/ellipse" />

            <ImageView
                android:id="@+id/ivStep5Dot"
                android:layout_width="15dp"
                android:layout_height="15dp"
                android:layout_gravity="center|bottom"
                android:src="@drawable/ellipse" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvStep1Title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/montserrat_bold"
                android:text="Almacén origen"
                android:textColor="@color/principal"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/tvStep1Subtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/montserrat_medium"
                android:text="Pendiente"
                android:textColor="@color/texto_claro"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/tvStep2Title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:fontFamily="@font/montserrat_bold"
                android:text="Puerto origen"
                android:textColor="@color/principal"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/tvStep2Subtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/montserrat_medium"
                android:text="Pendiente"
                android:textColor="@color/texto_claro"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/tvStep3Title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:fontFamily="@font/montserrat_bold"
                android:text="En tránsito"
                android:textColor="@color/principal"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/tvStep3Subtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/montserrat_medium"
                android:text="Pendiente"
                android:textColor="@color/texto_claro"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/tvStep4Title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:fontFamily="@font/montserrat_bold"
                android:text="Puerto destino"
                android:textColor="@color/principal"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/tvStep4Subtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/montserrat_medium"
                android:text="Pendiente"
                android:textColor="@color/texto_claro"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/tvStep5Title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:fontFamily="@font/montserrat_bold"
                android:text="Entrega final"
                android:textColor="@color/principal"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/tvStep5Subtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/montserrat_medium"
                android:text="Pendiente"
                android:textColor="@color/texto_claro"
                android:textSize="15sp" />
        </LinearLayout>
    </LinearLayout>

    <Button
        android:id="@+id/btnVolve"
        android:layout_width="200dp"
        android:layout_height="40dp"
        android:layout_gravity="center"
        android:layout_marginBottom="10dp"
        android:background="@drawable/btn_blue"
        android:fontFamily="@font/montserrat_bold"
        android:text="Volve"
        android:textColor="@color/background"
        android:textSize="20sp" />
</LinearLayout>
