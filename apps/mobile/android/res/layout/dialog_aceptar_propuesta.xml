<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/dialog_rechazo_background"
    android:orientation="vertical"
    android:paddingHorizontal="22dp"
    android:paddingTop="28dp"
    android:paddingBottom="22dp">

    <TextView
        android:id="@+id/tvAcceptDialogTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fontFamily="@font/montserrat_bold"
        android:gravity="center"
        android:text="Confirmar aceptacion"
        android:textColor="@color/principal"
        android:textSize="25sp" />

    <TextView
        android:id="@+id/tvAcceptDialogMessage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:fontFamily="@font/montserrat_medium"
        android:gravity="center"
        android:text="¿Seguro que quieres aceptar esta propuesta?"
        android:textColor="@color/principal"
        android:textSize="15sp" />

    <CheckBox
        android:id="@+id/cbConfirmAccept"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:buttonTint="@color/principal"
        android:fontFamily="@font/montserrat_bold"
        android:text="Marca la casilla para confirmar"
        android:textColor="@color/principal"
        android:textSize="16sp" />

    <Button
        android:id="@+id/btnConfirmAccept"
        android:layout_width="156dp"
        android:layout_height="52dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="16dp"
        android:background="@drawable/btn_blue"
        android:enabled="false"
        android:fontFamily="@font/montserrat_bold"
        android:text="Aceptar"
        android:textAllCaps="false"
        android:textColor="@android:color/white"
        android:textSize="18sp" />

</LinearLayout>
