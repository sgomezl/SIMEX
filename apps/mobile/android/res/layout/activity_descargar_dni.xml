<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/mainActivityDescargarDni"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/principal"
        android:columnCount="3"
        android:rowCount="1"
        android:elevation="12dp">

        <ImageButton
            android:id="@+id/btnHomeUsuario"
            android:layout_column="0"
            android:layout_row="0"
            android:layout_width="130dp"
            android:layout_height="85dp"
            android:layout_marginStart="20dp"
            android:background="@android:color/transparent"
            android:contentDescription="Volver a home"
            android:scaleType="fitCenter"
            android:src="@drawable/white_logo" />
    </GridLayout>

    <Space
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:layout_gravity="end"
        android:layout_marginTop="10dp"
        android:layout_marginRight="10dp" />

    <ImageView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="20dp"
        android:src="@drawable/usuario_blue" />

    <TextView
        android:id="@+id/tvUserName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="10dp"
        android:fontFamily="@font/montserrat_bold"
        android:text="Cargando usuario..."
        android:textColor="@color/principal"
        android:textSize="23sp" />

    <TextView
        android:id="@+id/tvCompanyName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="10dp"
        android:fontFamily="@font/montserrat_bold"
        android:text="Empresa"
        android:textColor="@color/destacado"
        android:textSize="20sp" />

    <TextView
        android:id="@+id/tvArchivoDni"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="40dp"
        android:fontFamily="@font/montserrat_bold"
        android:text="Documento listo para descargar"
        android:textColor="@color/principal" />

    <ImageView
        android:id="@+id/ivDniPreview"
        android:layout_width="280dp"
        android:layout_height="180dp"
        android:layout_gravity="center"
        android:layout_marginTop="16dp"
        android:adjustViewBounds="true"
        android:background="@drawable/txtbox_white"
        android:contentDescription="Vista previa del DNI"
        android:padding="8dp"
        android:scaleType="fitCenter" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="18dp"
        android:gravity="center"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btnDescargarDNI"
            android:layout_width="152dp"
            android:layout_height="46dp"
            android:background="@drawable/btn_orange"
            android:fontFamily="@font/montserrat_bold"
            android:text="Descargar DNI"
            android:textColor="@color/background"
            android:textSize="15sp" />

        <Button
            android:id="@+id/btnReuploadDNI"
            android:layout_width="152dp"
            android:layout_height="46dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/btn_orange"
            android:fontFamily="@font/montserrat_bold"
            android:text="Subir de nuevo"
            android:textColor="@color/background"
            android:textSize="15sp" />
    </LinearLayout>

    <Button
        android:id="@+id/btnVolver"
        android:layout_width="200dp"
        android:layout_height="45dp"
        android:layout_gravity="center"
        android:layout_marginTop="24dp"
        android:background="@drawable/btn_blue"
        android:fontFamily="@font/montserrat_bold"
        android:text="Volver"
        android:textColor="@color/background"
        android:textSize="20sp" />

</LinearLayout>
