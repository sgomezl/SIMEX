<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/mainActivityDescargarDni"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/principal"
        android:columnCount="3"
        android:rowCount="1"
        android:elevation="12dp">

        <ImageButton
            android:id="@+id/btnHomeUsuario"
            android:layout_column="0"
            android:layout_row="0"
            android:layout_width="130dp"
            android:layout_height="85dp"
            android:layout_marginStart="20dp"
            android:background="@android:color/transparent"
            android:contentDescription="Volver a home"
            android:scaleType="fitCenter"
            android:src="@drawable/white_logo" />
    </GridLayout>

    <Space
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:layout_gravity="end"
        android:layout_marginTop="10dp"
        android:layout_marginRight="10dp" />

    <ImageView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="20dp"
        android:src="@drawable/usuario_blue" />

    <TextView
        android:id="@+id/tvUserName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="10dp"
        android:fontFamily="@font/montserrat_bold"
        android:text="Cargando usuario..."
        android:textColor="@color/principal"
        android:textSize="23sp" />

    <TextView
        android:id="@+id/tvCompanyName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="10dp"
        android:fontFamily="@font/montserrat_bold"
        android:text="Empresa"
        android:textColor="@color/destacado"
        android:textSize="20sp" />

    <TextView
        android:id="@+id/tvArchivoDni"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="80dp"
        android:fontFamily="@font/montserrat_bold"
        android:text="Documento listo para descargar"
        android:textColor="@color/principal" />

    <Button
        android:id="@+id/btnDescargarDNI"
        android:layout_width="220dp"
        android:layout_height="50dp"
        android:layout_gravity="center"
        android:layout_marginTop="14dp"
        android:background="@drawable/btn_blue"
        android:fontFamily="@font/montserrat_bold"
        android:text="Descargar DNI"
        android:textColor="@color/background"
        android:textSize="20sp" />

    <Button
        android:id="@+id/btnVolver"
        android:layout_width="200dp"
        android:layout_height="45dp"
        android:layout_gravity="center"
        android:layout_marginTop="180dp"
        android:background="@drawable/btn_blue"
        android:fontFamily="@font/montserrat_bold"
        android:text="Volver"
        android:textColor="@color/background"
        android:textSize="20sp" />

</LinearLayout>
