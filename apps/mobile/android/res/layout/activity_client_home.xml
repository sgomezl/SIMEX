<GridLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:columnCount="1"
    android:rowCount="8">
    <GridLayout
        android:layout_row="0"
        android:layout_column="0"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/principal"
        android:columnCount="3"
        android:rowCount="1"
        android:elevation="12dp">
        <ImageButton
            android:id="@+id/btn_home"
            android:layout_column="0"
            android:layout_row="0"
            android:layout_width="130dp"
            android:layout_height="85dp"
            android:layout_marginStart="20dp"
            android:scaleType="fitCenter"
            android:src="@drawable/white_logo"
            android:background="@android:color/transparent">
        </ImageButton>
        <ImageButton
            android:id="@+id/btn_notifications"
            android:layout_column="1"
            android:layout_row="0"
            android:layout_gravity="center_vertical"
            android:layout_width="30dp"
            android:layout_height="65dp"
            android:layout_marginStart="150dp"
            android:scaleType="fitCenter"
            android:src="@drawable/notifications"
            android:background="@android:color/transparent">
        </ImageButton>
        <ImageButton
            android:id="@+id/btn_user"
            android:layout_column="2"
            android:layout_row="0"
            android:layout_gravity="center_vertical"
            android:layout_width="50dp"
            android:layout_height="65dp"
            android:layout_marginStart="20dp"
            android:padding="5dp"
            android:scaleType="fitCenter"
            android:src="@drawable/login_user"
            android:background="@android:color/transparent">
        </ImageButton>
    </GridLayout>
    <!-- Línea divisora  -->
    <View
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:background="#000000"/>
    <TextView
        android:id="@+id/txt_greeting"
        android:layout_column="0"
        android:layout_row="1"
        android:layout_margin="10dp"
        android:text="Hola, Francisco"
        android:fontFamily="@font/montserrat_bold"
        android:textColor="@color/principal"
        android:paddingRight="10dp"
        android:paddingLeft="10dp"
        android:textSize="25dp"
        android:textStyle="bold"
        android:paddingBottom="2dp" >
    </TextView>
    <GridLayout
        android:layout_column="0"
        android:layout_row="2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginBottom="20dp">
        <EditText
            android:id="@+id/et_search"
            android:layout_width="250dp"
            android:layout_height="45dp"
            android:background="@drawable/txtbox_orange"
            android:fontFamily="@font/montserrat_medium"
            android:inputType="textPassword"
            android:padding="5dp">
        </EditText>
        <ImageButton
            android:id="@+id/btn_qr"
            android:layout_width="45dp"
            android:layout_height="45dp"
            android:background="@drawable/btn_qr"
            android:src="@drawable/qr"
            android:scaleType="fitCenter"
            android:padding="4dp">
        </ImageButton>
        <ImageButton
            android:id="@+id/btn_search"
            android:layout_width="45dp"
            android:layout_height="45dp"
            android:layout_marginStart="20dp"
            android:background="@drawable/btn_search"
            android:src="@drawable/search"
            android:scaleType="fitCenter"
            android:padding="5dp">
        </ImageButton>
    </GridLayout>
    <TextView
        android:id="@+id/txt_remaining"
        android:layout_column="0"
        android:layout_row="3"
        android:layout_margin="10dp"
        android:text="Propuestas pendientes:"
        android:fontFamily="@font/montserrat_bold"
        android:textColor="@color/principal"
        android:paddingRight="10dp"
        android:paddingLeft="10dp"
        android:textSize="25dp"
        android:textStyle="bold"
        android:paddingBottom="2dp" >
        </TextView>
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_proposals"
        android:layout_column="0"
        android:layout_row="4"
        android:layout_marginStart="20dp">
    </androidx.recyclerview.widget.RecyclerView>
    <TextView
        android:id="@+id/txt_recent"
        android:layout_column="0"
        android:layout_row="5"
        android:layout_margin="10dp"
        android:text="Operaciones recientes:"
        android:fontFamily="@font/montserrat_bold"
        android:textColor="@color/principal"
        android:paddingRight="10dp"
        android:paddingLeft="10dp"
        android:textSize="25dp"
        android:textStyle="bold"
        android:paddingBottom="2dp" >
    </TextView>
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_recent"
        android:layout_column="0"
        android:layout_row="6"
        android:layout_marginStart="20dp">
    </androidx.recyclerview.widget.RecyclerView>
    <Button
        android:id="@+id/btn_seeAll"
        android:layout_column="0"
        android:layout_row="7"
        android:layout_width="wrap_content"
        android:layout_height="45dp"
        android:layout_marginStart="20dp"
        android:background="@drawable/btn_seeAll"
        android:fontFamily="@font/montserrat_bold"
        android:text="Ver todas"
        android:textColor="@color/background"
        android:textSize="20sp"
        android:layout_gravity="center"
        android:padding="10dp">
    </Button>
</GridLayout>
